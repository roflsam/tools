# Google OAuth credentials (from Cloud Console → APIs & Services → Credentials)
GOOGLE_OAUTH_CLIENT_ID="your-client-id.apps.googleusercontent.com"
GOOGLE_OAUTH_CLIENT_SECRET="your-client-secret"

# Your Gmail address (used for auth and receipt search)
USER_GOOGLE_EMAIL="you@gmail.com"

# Required for local OAuth callback (localhost isn't HTTPS)
OAUTHLIB_INSECURE_TRANSPORT=1
